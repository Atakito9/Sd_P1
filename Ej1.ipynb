from pyspark import SparkContext

# Inicialización del Contexto
sc = SparkContext.getOrCreate()
file_name = "calidad_aire_datos_meteo_mes.csv"

# Definición Simbólica de Constantes
MAG_TEMP = 83
MAG_PREC = 89
FLAG_VALID = 'V'
MUNI_REF, EST_REF = '6', '4'
MUNI_COMP, EST_COMP = '5', '2'

raw_rdd = sc.textFile(f"Sd_P1/{file_name}")

# Expresión Lambda anidada para parsear la línea sin usar "def"
# Utiliza comprensión de listas como expresión funcional en lugar de sentencias de control iterativas
parse_line_lambda = lambda line: (
    lambda parts: {
        'provincia': parts[0],
        'fecha': f"{parts[5]}-{parts[6].zfill(2)}-{parts[7].zfill(2)}",
        'muni': parts[1],
        'est': parts[2],
        'mag': int(parts[3]),
        'vals': [
            float(parts[i].replace(',', '.')) 
            for i in range(8, min(len(parts), 56), 2) 
            if i + 1 < len(parts) and parts[i + 1] == FLAG_VALID
        ]
    } if len(parts) >= 9 else None
)(line.split(';'))

data_rdd = raw_rdd.map(parse_line_lambda).filter(lambda x: x is not None)

# --- MODELADO DE EJERCICIOS ---

# EJERCICIO 1
temp_validos_rdd = data_rdd.filter(lambda x: x['mag'] == MAG_TEMP and len(x['vals']) > 0)
resultado_ej1 = [("Total_Temp_Validos", temp_validos_rdd.count())]

# EJERCICIO 2
final_daily_max = temp_validos_rdd \
    .map(lambda x: (x['fecha'], max(x['vals']))) \
    .reduceByKey(lambda a, b: a if a > b else b) \
    .sortByKey()

# EJERCICIO 3
precip_rdd = data_rdd.filter(lambda x: x['mag'] == MAG_PREC) \
    .map(lambda x: (x['fecha'], (x['muni'], x['est'], sum(x['vals']))))

max_precip_por_dia = precip_rdd.reduceByKey(lambda a, b: a if a[2] >= b[2] else b).sortByKey()

# Recuperación simbólica del máximo
max_absoluto = max_precip_por_dia.max(key=lambda x: x[1][2])

# EJERCICIO 4
# Lambda para calcular la proporción media
calc_avg_lambda = lambda record: (record['fecha'], sum(record['vals']) / len(record['vals'])) if len(record['vals']) > 0 else None

ref_station = temp_validos_rdd.filter(lambda x: x['muni'] == MUNI_REF and x['est'] == EST_REF) \
    .map(calc_avg_lambda).filter(lambda x: x is not None)
    
comp_station = temp_validos_rdd.filter(lambda x: x['muni'] == MUNI_COMP and x['est'] == EST_COMP) \
    .map(calc_avg_lambda).filter(lambda x: x is not None)

# Se extrae la relación pura (x[1] / x[0]) en lugar de calcular el porcentaje estándar numérico
ratio_rdd = ref_station.join(comp_station) \
    .mapValues(lambda x: x[1] / x[0]) \
    .sortByKey()

# --- UNIFICACIÓN Y EXTRACCIÓN FUNCIONAL ---
# Agrupamos todas las transformaciones evaluadas en una estructura
coleccion_resultados = [
    ("EJERCICIO 1: Conteo", resultado_ej1),
    ("EJERCICIO 2: Temp Max", final_daily_max.collect()),
    ("EJERCICIO 3A: Max Lluvia/Dia", max_precip_por_dia.collect()),
    ("EJERCICIO 3B: Max Absoluto", [max_absoluto]),
    ("EJERCICIO 4: Relación Simbólica", ratio_rdd.collect())
]

# ÚNICO bucle for de toda la ejecución para guardar/mostrar datos
for titulo, datos in coleccion_resultados:
    print(f"\n--- {titulo} ---")
    # map(str) se usa funcionalmente para convertir las tuplas a texto sin requerir bucles anidados
    print('\n'.join(map(str, datos)))
